{
  "nodes": [
    {
      "id": "init-started",
      "type": "otel-event",
      "x": 100,
      "y": 50,
      "width": 200,
      "height": 100,
      "color": "#22c55e",
      "label": "Init Started",
      "fill": "#22c55e",
      "shape": "rectangle",
      "event": {
        "name": "core.init.started",
        "attributes": {
          "projectRoot": {
            "type": "string",
            "required": true
          },
          "mode": {
            "type": "string",
            "required": true,
            "description": "Initialization mode: 'full' or 'lazy'"
          }
        }
      },
      "otel": {
        "status": "implemented",
        "files": [
          "src/core/Core.ts"
        ]
      }
    },
    {
      "id": "config-loaded",
      "type": "otel-event",
      "x": 100,
      "y": 250,
      "width": 200,
