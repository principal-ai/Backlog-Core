      "fill": "#3b82f6",
      "shape": "rectangle",
      "event": {
        "name": "core.init.config.loaded",
        "attributes": {
          "projectName": {
            "type": "string",
            "required": true
          },
          "statusCount": {
            "type": "number",
            "required": true
          },
          "labelCount": {
            "type": "number",
            "required": false
          }
        }
