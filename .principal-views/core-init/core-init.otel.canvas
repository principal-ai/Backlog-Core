    {
      "id": "init-error",
      "type": "otel-event",
      "x": 450,
      "y": 250,
      "width": 200,
      "height": 100,
      "color": "#ef4444",
      "label": "Init Error",
      "fill": "#ef4444",
      "shape": "rectangle",
      "event": {
        "name": "core.init.error",
        "attributes": {
          "error.type": {
            "type": "string",
            "required": true
          },
          "error.message": {
            "type": "string",
            "required": true
          },
          "stage": {
            "type": "string",
            "required": false,
            "description": "Stage where error occurred: config, tasks, etc."
