  "edges": [
    {
      "id": "started-to-config",
      "fromNode": "init-started",
      "fromSide": "bottom",
      "toNode": "config-loaded",
      "toSide": "top",
      "pv": {
        "edgeType": "flow"
      }
    },
    {
      "id": "config-to-tasks",
      "fromNode": "config-loaded",
      "fromSide": "bottom",
      "toNode": "tasks-loaded",
      "toSide": "top",
      "pv": {
        "edgeType": "flow"
      }
    },
    {
      "id": "tasks-to-complete",
      "fromNode": "tasks-loaded",
      "fromSide": "bottom",
      "toNode": "init-complete",
      "toSide": "top",
      "pv": {
        "edgeType": "flow"
      }
    },
    {
      "id": "started-to-error",
      "fromNode": "init-started",
      "fromSide": "right",
      "toNode": "init-error",
      "toSide": "left",
      "pv": {
        "edgeType": "error"
      }
    },
    {
      "id": "config-to-error",
      "fromNode": "config-loaded",
      "fromSide": "right",
      "toNode": "init-error",
      "toSide": "left",
      "pv": {
        "edgeType": "error"
      }
    },
    {
      "id": "tasks-to-indexed",
      "fromNode": "tasks-loaded",
      "fromSide": "bottom",
      "toNode": "init-indexed",
      "toSide": "top",
      "pv": {
        "edgeType": "lazy"
      }
    }
  ],
  "pv": {
    "name": "Core Initialization",
    "version": "1.0.0",
    "description": "OpenTelemetry events for Backlog-Core initialization workflow",
    "markdown": ".principal-views/core-init/core-init.md",
    "edgeTypes": {
      "flow": {
        "label": "Flow",
        "style": "solid",
        "width": 2,
        "color": "#64748b"
      },
      "lazy": {
        "label": "Lazy Mode",
        "style": "solid",
        "width": 2,
