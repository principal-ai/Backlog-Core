			"x": 760,
			"y": 100,
			"width": 180,
			"height": 80,
			"text": "# task.delete\n\nTask deletion span",
			"color": "#f97316",
			"pv": {
				"otel": {
					"spanPattern": "task.delete"
				},
				"shape": "rectangle",
				"fill": "#f97316",
				"stroke": "#ea580c"
			}
		},
		{
			"id": "task-archive-span",
			"type": "text",
			"x": 320,
			"y": 220,
			"width": 180,
			"height": 80,
			"text": "# task.archive\n\nTask archive span",
			"color": "#8b5cf6",
			"pv": {
				"otel": {
					"spanPattern": "task.archive"
				},
				"shape": "rectangle",
