{
	"pv": {
		"name": "Backlog Core Spans",
		"version": "1.0.0",
		"description": "OpenTelemetry span conventions for @backlog-md/core operations",
		"markdown": ".principal-views/architecture.md"
	},
	"nodes": [
		{
			"id": "core-init-span",
			"type": "text",
			"x": 100,
			"y": 100,
			"width": 180,
			"height": 80,
			"text": "# core.init\n\nCore initialization span",
			"color": "#22c55e",
			"pv": {
				"otel": {
					"spanPattern": "core.init"
				},
				"shape": "rectangle",
				"fill": "#22c55e",
				"stroke": "#16a34a"
			}
		},
		{
			"id": "task-create-span",
			"type": "text",
			"x": 320,
			"y": 100,
			"width": 180,
			"height": 80,
			"text": "# task.create\n\nTask creation span",
			"color": "#3b82f6",
			"pv": {
				"otel": {
					"spanPattern": "task.create"
				},
				"shape": "rectangle",
				"fill": "#3b82f6",
				"stroke": "#1d4ed8"
			}
		},
		{
			"id": "task-update-span",
			"type": "text",
			"x": 540,
			"y": 100,
			"width": 180,
			"height": 80,
