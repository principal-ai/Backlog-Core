			"fromSide": "right",
			"toNode": "task-delete-span",
			"toSide": "left",
			"pv": { "edgeType": "Dependency" }
		},
		{
			"id": "task-create-to-archive",
			"fromNode": "task-create-span",
			"fromSide": "bottom",
			"toNode": "task-archive-span",
			"toSide": "top",
			"pv": { "edgeType": "Dependency" }
		},
		{
			"id": "task-archive-to-restore",
			"fromNode": "task-archive-span",
			"fromSide": "right",
			"toNode": "task-restore-span",
			"toSide": "left",
			"pv": { "edgeType": "Dependency" }
