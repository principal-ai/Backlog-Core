			"type": "text",
			"x": 540,
			"y": 220,
			"width": 180,
			"height": 80,
			"text": "# task.restore\n\nTask restore span",
			"color": "#06b6d4",
			"pv": {
				"otel": {
					"spanPattern": "task.restore"
				},
				"shape": "rectangle",
				"fill": "#06b6d4",
				"stroke": "#0891b2"
			}
		},
		{
			"id": "milestone-create-span",
			"type": "text",
			"x": 100,
			"y": 340,
			"width": 180,
			"height": 80,
			"text": "# milestone.create\n\nMilestone creation span",
			"color": "#22c55e",
			"pv": {
				"otel": {
					"spanPattern": "milestone.create"
				},
